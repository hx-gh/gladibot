      "name": "Chance for Hit",
      "rawText": "Your Dexterity / (Your Dexterity + Enemies Agility) * 100",
      "expression": "Math.floor((dexterity / (dexterity + enemyAgility)) * 100)",
      "inputs": ["dexterity", "enemyAgility"],
      "output": "hitChancePct",
      "notes": "Round down. Yields a percent (0-100)."
    },
    {
      "id": "chance-double-hit",
      "category": "combat",
      "name": "Chance for Double Hit",
      "rawText": "Your Charisma * Your Dexterity / Enemy Intelligence / Enemy Agility * 10",
      "expression": "(charisma * dexterity / enemyIntelligence / enemyAgility) * 10",
      "inputs": ["charisma", "dexterity", "enemyIntelligence", "enemyAgility"],
      "output": "doubleHitChancePct",
      "notes": "Source order is left-to-right division then multiply by 10. Yields a percent."
