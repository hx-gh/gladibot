  "formulas": [
    {
      "id": "max-health",
      "category": "health",
      "name": "Max Health Points",
      "rawText": "Max Health = Health from level + Health through constitution + Health from items + Health from reinforcements",
      "expression": "healthFromLevel + healthFromConstitution + healthFromItems + healthFromReinforcements",
      "inputs": ["healthFromLevel", "healthFromConstitution", "healthFromItems", "healthFromReinforcements"],
      "output": "maxHealth",
      "notes": "Additive components. Guild/blessing/costume buffs stack additively on top."
    },
    {
      "id": "health-from-level",
      "category": "health",
      "name": "Health from Level",
      "rawText": "Character Level * 25",
      "expression": "characterLevel * 25",
      "inputs": ["characterLevel"],
      "output": "healthFromLevel",
      "notes": ""
    },
    {
      "id": "health-from-constitution",
      "category": "health",
      "name": "Health from Constitution",
      "rawText": "(Constitution*25)-50",
      "expression": "(constitution * 25) - 50",
      "inputs": ["constitution"],
      "output": "healthFromConstitution",
      "notes": "Constitution coefficient is 25, not 2 (one of the source summaries was inconsistent; verbatim text uses 25)."
    },
    {
      "id": "regen-per-hour",
      "category": "regen",
      "name": "Base HP Regeneration per Hour",
      "rawText": "Through Level + Through Constitution",
      "expression": "regenFromLevel + regenFromConstitution",
      "inputs": ["regenFromLevel", "regenFromConstitution"],
      "output": "regenPerHour",
      "notes": "Buffs from guild/blessing/costume stack additively."
    },
    {
      "id": "regen-from-level",
      "category": "regen",
      "name": "Regen Through Level",
      "rawText": "Character Level * 2",
      "expression": "characterLevel * 2",
      "inputs": ["characterLevel"],
      "output": "regenFromLevel",
      "notes": ""
    },
    {
      "id": "regen-from-constitution",
      "category": "regen",
      "name": "Regen Through Constitution",
      "rawText": "Constitution * 2",
      "expression": "constitution * 2",
      "inputs": ["constitution"],
      "output": "regenFromConstitution",
      "notes": ""
    },
    {
      "id": "experience-required",
      "category": "experience",
      "name": "Experience Required for Next Level",
      "rawText": "Levels 1-52: (10*(level+1)-5)-10 ; Levels 53-79: (10*(level+0.5))-10 ; Level 80+: unknown",
      "expression": null,
      "branches": [
        {
          "when": "level >= 1 && level <= 52",
          "expression": "(10 * (level + 1) - 5) - 10"
        },
        {
          "when": "level >= 53 && level <= 79",
          "expression": "(10 * (level + 0.5)) - 10"
        },
        {
          "when": "level >= 80",
          "expression": null,
          "_review": "Source marks formula as unknown for level 80+."
        }
      ],
      "inputs": ["level"],
      "output": "experienceToNext",
      "notes": "Piecewise by level band."
    },
    {
      "id": "max-stat-value",
      "category": "stats",
      "name": "Maximum Stat Value (Effective Cap)",
      "rawText": "Basic trained stat + (basic / 2) + Character Level",
      "expression": "trainedStat + (trainedStat / 2) + characterLevel",
      "inputs": ["trainedStat", "characterLevel"],
      "output": "maxStatValue",
      "notes": "Items, dusts, holy oils cannot push a stat above this cap. Pacts, Godly rank 1 buffs, and reinforcements can temporarily exceed it."
    },
    {
      "id": "max-training-cap",
      "category": "stats",
      "name": "Maximum Stat via Training",
      "rawText": "Character Level * 5 (capped at 200 for levels 1-40)",
      "expression": "Math.min(characterLevel * 5, characterLevel <= 40 ? 200 : Infinity)",
      "branches": [
        {
          "when": "characterLevel <= 40",
          "expression": "Math.min(characterLevel * 5, 200)"
        },
        {
          "when": "characterLevel > 40",
          "expression": "characterLevel * 5"
        }
      ],
      "inputs": ["characterLevel"],
      "output": "maxTrainedStat",
      "notes": "Hard cap of 200 only applies through level 40."
    },
    {
      "id": "min-damage",
      "category": "combat",
      "name": "Minimum Damage",
      "rawText": "Weapon minimal damage + damage through items + (Strength / 10)",
      "expression": "weaponMinDamage + damage + (strength / 10)",
      "inputs": ["weaponMinDamage", "damage", "strength"],
      "output": "minDamage",
      "notes": "`damage` is the affix-catalog key for damage from items."
    },
    {
      "id": "max-damage",
      "category": "combat",
      "name": "Maximum Damage",
      "rawText": "Weapon maximal damage + damage through items + (Strength / 10)",
      "expression": "weaponMaxDamage + damage + (strength / 10)",
      "inputs": ["weaponMaxDamage", "damage", "strength"],
      "output": "maxDamage",
      "notes": ""
    },
    {
      "id": "min-armour-absorption",
      "category": "defense",
      "name": "Minimum Armour Absorption",
      "rawText": "(Armour/74)-(Armour/74)/660+1 [round up]",
      "expression": "Math.ceil((armour / 74) - (armour / 74) / 660 + 1)",
      "inputs": ["armour"],
      "output": "minArmourAbsorption",
      "notes": "Round up. Source uses 'Armour' (en-GB)."
    },
    {
      "id": "max-armour-absorption",
      "category": "defense",
      "name": "Maximum Armour Absorption",
      "rawText": "(Armour/66)+(Armour/660) [round down]",
      "expression": "Math.floor((armour / 66) + (armour / 660))",
      "inputs": ["armour"],
      "output": "maxArmourAbsorption",
      "notes": "Round down."
    },
    {
