# Servidor base. Se trocar de provincia, ajuste só essa linha.
BASE_URL=https://s62-br.gladiatus.gameforge.com

# URL onde o browser abre primeiro pra você fazer login Google e selecionar servidor.
# O bot espera você cair em ${BASE_URL}/game/index.php pra continuar.
LOBBY_URL=https://lobby.gladiatus.gameforge.com/

# Diretório onde o Playwright guarda o perfil do browser (cookies, localStorage).
# Login Google é feito uma vez, fica salvo aqui pros runs seguintes.
USER_DATA_DIR=./browser-data

# Canal do browser. "msedge" usa o Edge instalado (recomendado — Google
# tolera melhor que chromium puro). Outras opções: "chrome", "chromium".
BROWSER_CHANNEL=msedge

# Headless: false na primeira run (pra você fazer login). Pode ligar pra true
# depois que a sessão estiver salva — bot fica invisível em background.
HEADLESS=false

# Configuração de gameplay
EXPEDITION_LOCATION=2
EXPEDITION_STAGE=2          # 2 = Escaravelho Gigante na Caverna de Sangue
HEAL_THRESHOLD_PCT=20       # cura quando HP cair abaixo disso
WORK_HOURS=8

# Bot tuning
LOOP_TICK_MIN_MS=2000
LOG_LEVEL=info              # debug | info | warn | error
