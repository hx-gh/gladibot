# Servidor base. Se trocar de provincia, ajuste só essa linha.
BASE_URL=https://s62-br.gladiatus.gameforge.com

# URL onde o browser abre primeiro pra você fazer login Google e selecionar servidor.
# O bot espera você cair em ${BASE_URL}/game/index.php pra continuar.
LOBBY_URL=https://lobby.gladiatus.gameforge.com/

# Diretório onde o Playwright guarda o perfil do browser (cookies, localStorage).
# Login Google é feito uma vez, fica salvo aqui pros runs seguintes.
USER_DATA_DIR=./browser-data

# Canal do browser. "msedge" usa o Edge instalado (recomendado — Google
# tolera melhor que chromium puro). Outras opções: "chrome", "chromium".
BROWSER_CHANNEL=msedge

# Headless: false na primeira run (pra você fazer login). Pode ligar pra true
# depois que a sessão estiver salva — bot fica invisível em background.
HEADLESS=false

# Configuração de gameplay
# A região de mapa de cada `loc=N` muda conforme o char sobe de nível.
# Confirmar pela URL `index.php?mod=location&loc=<N>` antes de fixar.
EXPEDITION_LOCATION=3       # ex: 3 = Monte da Morte (lvl 58+)
EXPEDITION_STAGE=2          # 1..5 = posição do monstro alvo dentro da location
DUNGEON_LOCATION=1          # ex: 1 = A Floresta Verde (lvl 58+)
DUNGEON_SKIP_BOSS=true      # pula o boss (div.map_label "Chefe"). Evita queimar pontos em boss mais forte que o char.
HEAL_THRESHOLD_PCT=20       # cura quando HP cair abaixo disso
WORK_HOURS=8

# Top-off de cura — packages + autobuy no leilão (DEC-26).
# Roda antes do AFK fallback: se inventário tem menos de AUTOBUY_HEAL_TARGET
# itens, primeiro drena packages com `Usar: Cura X` (free), depois tenta
# comprar no leilão. Lance manual via UI também é gateado por bucket "Curto".
PACKAGES_ENABLED=true               # drenar packages com itens de cura
AUTOBUY_HEAL_ENABLED=true           # compra automática no leilão (itemType=7)
AUTOBUY_HEAL_TARGET=5               # nº mínimo de itens de cura no inventário
AUTOBUY_HEAL_MIN_RATIO=3            # filtro heal/preço — só compra se heal ≥ ratio × preço (ex: 3 = item 300g tem que curar ≥900)
AUTOBUY_HEAL_MAX_BUDGET_TICK=50000  # ouro máximo gasto em cura por tick (proteção)

# Bot tuning
LOOP_TICK_MIN_MS=2000
LOG_LEVEL=info              # debug | info | warn | error

# Master kill switch. false = bot só observa (sem heal/exp/dung/work).
# Pode ser ligado/desligado a quente pela UI; CLI --no-actions força false.
ACTIONS_ENABLED=true

# UI (control panel) — só sobe em --loop. Bind sempre em 127.0.0.1.
UI_ENABLED=true
UI_PORT=3000
UI_AUTO_OPEN=true           # abre http://localhost:<port> no browser default ao subir
