{
  "name": "gladibot",
  "version": "0.2.0",
  "private": true,
  "description": "Gladiatus bot monorepo (TurboRepo + pnpm)",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=18.17",
    "pnpm": ">=10"
  },
  "scripts": {
    "tick": "pnpm --filter @gladibot/bot tick",
    "loop": "pnpm --filter @gladibot/bot loop",
    "ui": "pnpm --filter @gladibot/bot ui",
    "bot:tick": "pnpm --filter @gladibot/bot tick",
    "bot:loop": "pnpm --filter @gladibot/bot loop",
    "bot:ui": "pnpm --filter @gladibot/bot ui",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  }
}
